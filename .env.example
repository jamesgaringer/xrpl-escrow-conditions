# Testnet only — never use mainnet seeds in a sample file or commit `.env`.

# Wallet that signs EscrowCreate / EscrowFinish in the demo script
INITIATOR_SEED=sXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Destination r-address (receives escrowed XRP after successful finish)
DESTINATION_ADDRESS=rXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: second seed for `fetchTwoWalletSnapshots` in `example.ts`
SECOND_WALLET_SEED=

# Optional: run `npm test` with on-ledger create (funded accounts required)
# INTEGRATION_TEST_SEED=
# INTEGRATION_DESTINATION=
