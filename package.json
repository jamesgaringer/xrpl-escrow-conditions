  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "five-bells-condition": "^5.0.1",
    "xrpl": "^2.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
